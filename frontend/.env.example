# Optional: absolute site URL for Open Graph / metadata (production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: primary Ethereum JSON-RPC for POST /api/rpc/public (strongly recommended — avoids public RPC 429s)
# RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# ETHEREUM_RPC_URL=https://...
#
# Optional: comma- or space-separated extra RPCs; used when primary returns 429/503
# RPC_FALLBACK_URLS=https://eth.llamarpc.com,https://ethereum.publicnode.com

# ── Ledger Wallet Provider ─────────────────────────────────────────────────
# Requires enrollment in Ledger's partner program:
#   https://developers.ledger.com/docs/ledger-wallet-provider/overview
# NEXT_PUBLIC_LEDGER_API_KEY=your-ledger-api-key
# NEXT_PUBLIC_LEDGER_DAPP_IDENTIFIER=vanta
